{
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=5432;Database=identitydb;Username=postgres;Password=postgres",
    "RabbitMq": "rabbitmq://guest:guest@localhost:5672"
  },
  "Jwt": {
    "Issuer": "marketplace.identity",
    "Audience": "marketplace.clients",
    "Secret": "identity-super-secret-key-at-least-thirty-two-characters",
    "AccessTokenLifetimeMinutes": 15,
    "RefreshTokenLifetimeDays": 30
  },
  "OpenTelemetry": {
    "OtlpEndpoint": "http://localhost:4317"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
